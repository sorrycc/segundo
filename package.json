{
  "name": "segundo",
  "version": "0.0.0-alpha.0",
  "description": "Human memory - a zero-friction second brain CLI",
  "type": "module",
  "bin": {
    "segundo": "./dist/src/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "tsc",
    "build:bin": "bun build src/cli.ts --compile --outfile segundo",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write .",
    "release": "bun scripts/release.ts"
  },
  "license": "MIT",
  "keywords": [
    "second-brain",
    "memory",
    "notes",
    "cli"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
